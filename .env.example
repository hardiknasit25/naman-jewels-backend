# Copy to .env and adjust for your environment.
PORT=3000
NODE_ENV=development

# CORS: origins allowed to call this API (the frontend app runs separately).
# "*" allows any origin; or a comma-separated list of exact origins, e.g.
# http://localhost:5173,https://admin.namanjewels.com
CORS_ORIGIN=*

# JWT
JWT_SECRET=change-me
# Default session length for the seeded admin (drives JWT expiry).
# One of: 2h | 4h | 12h | 1d | 1w | 1m
ADMIN_SESSION_DURATION=1d

# MySQL / Sequelize
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=naman_jewels
DB_USER=root
DB_PASSWORD=
DB_LOGGING=false
